{
  "name": "@mock-dash/monorepo",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "check": "turbo check",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "check:biome": "biome check --write .",
    "clean": "turbo clean && pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  }
}
